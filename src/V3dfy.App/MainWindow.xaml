                                            Style="{StaticResource ResponsiveLogHeaderButtonStyle}" />
                                    <Button Margin="4,0,0,0"
                                            AutomationProperties.AutomationId="ClearActivityLogButtonNarrow"
                                            Command="{Binding ClearLogsCommand}"
                                            Content="{Binding ClearText}"
                                            Style="{StaticResource ResponsiveLogHeaderButtonStyle}" />
                                </UniformGrid>
                            </StackPanel>
