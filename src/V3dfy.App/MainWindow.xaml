<Window x:Class="V3dfy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Icon="Assets/Branding/v3dfy.ico"
        Width="1120"
        Height="800"
        MinWidth="920"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        Drop="OnDrop">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WorkflowTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Background="Transparent"
                                      IsItemsHost="True" />
                            <Border Grid.Row="1"
                                    Padding="14"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WorkflowTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TabUnselectedForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource TabUnselectedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0">
                            <Grid>
                                <Border x:Name="AccentLine"
                                        Height="3"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource TabAccentBrush}"
                                        CornerRadius="3,3,0,0"
                                        Opacity="0" />
                                <ContentPresenter Margin="0,2,0,0"
                                                  ContentSource="Header"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TabSelectedForegroundBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource TabSelectedBackgroundBrush}" />
                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource TabSelectedBorderBrush}" />
                                <Setter TargetName="AccentLine"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24"
          Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image Width="42"
                       Height="42"
                       Margin="0,0,10,0"
                       Source="Assets/Branding/v3dfy-icon-left-square-transparent.png"
                       Stretch="Uniform" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding AppTitle}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}"
                               Text="{Binding SubtitleText}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding LanguageLabel}" />
                <ComboBox Margin="0,0,16,0"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedItem="{Binding SelectedLanguage}" />
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding ThemeLabel}" />
                <ComboBox ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding SelectedTheme}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Margin="0,0,4,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding NormalSetupVisibility}">
                <ScrollViewer.Resources>
                    <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                           TargetType="ScrollBar" />
                </ScrollViewer.Resources>
                <Grid Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding SelectSourceTitle}" />
                        <Border Padding="20"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DropVideoText}" />
                                <TextBlock Margin="0,6,0,14"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text=".mp4, .mkv, .avi, .mov, .m4v, .webm" />
                                <TextBlock Margin="0,0,0,14"
                                           Text="{Binding SelectedVideoDisplayPath}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding SelectVideoCommand}"
                                            Content="{Binding SelectVideoText}" />
                                    <Button Margin="10,0,0,0"
                                            Command="{Binding AnalyzeCommand}"
                                            Content="{Binding AnalyzeText}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <TabControl SelectedIndex="{Binding SelectedWorkflowTabIndex,
                                                        Mode=TwoWay}"
                                Style="{StaticResource WorkflowTabControlStyle}">
                        <TabItem Header="{Binding VideoAnalysisTitle}"
                                 Style="{StaticResource WorkflowTabItemStyle}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding AnalysisStatusText}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AnalysisDurationText}" />
                                        <TextBlock Text="{Binding AnalysisResolutionText}" />
                                        <TextBlock Text="{Binding AnalysisFpsText}" />
                                        <TextBlock Text="{Binding AnalysisCodecText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding AnalysisContainerText}" />
                                        <TextBlock Text="{Binding AnalysisAudioStreamsText}" />
                                        <TextBlock Text="{Binding AnalysisSubtitleStreamsText}" />
                                        <TextBlock Text="{Binding AnalysisHdrText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding AnalysisCompatibilityText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{Binding RecommendedSetupTitle}"
                                 IsEnabled="{Binding CanOpenRecommendedSetupTab}"
                                 Style="{StaticResource WorkflowTabItemStyle}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding RecommendedSetupStatusText}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding RecommendedOutputContainerText}" />
                                        <TextBlock Text="{Binding RecommendedVideoCodecText}" />
                                        <TextBlock Text="{Binding RecommendedAudioCodecText}" />
                                        <TextBlock Text="{Binding RecommendedResolutionText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding RecommendedThreeDLayoutText}" />
                                        <TextBlock Text="{Binding RecommendedQualityText}" />
                                        <TextBlock Text="{Binding RecommendedIntensityText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Margin="0,10,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding RecommendedNotesTitle}" />
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding RecommendedNotesText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{Binding ConversionPlanTitle}"
                                 IsEnabled="{Binding CanOpenConversionPlanTab}"
                                 Style="{StaticResource WorkflowTabItemStyle}">
                            <StackPanel>
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding PlanOptionsTitle}" />
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Margin="0,0,0,4"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding OutputPresetLabel}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding OutputPresetOptions}"
                                                          SelectedValue="{Binding SelectedOutputPreset}"
                                                          SelectedValuePath="Value" />
                                                <Button Grid.Column="2"
                                                        MinWidth="30"
                                                        Padding="8,5"
                                                        AutomationProperties.AutomationId="ShowProfileDetailsButton"
                                                        Command="{Binding ShowProfileDetailsCommand}"
                                                        Content="{Binding ProfileDetailsButtonText}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,4"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="{Binding OutputContainerOptionLabel}" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding OutputContainerOptions}"
                                                          SelectedValue="{Binding SelectedOutputContainer}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Margin="0,0,0,4"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="{Binding QualityOptionLabel}" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding QualityPresetOptions}"
                                                          SelectedValue="{Binding SelectedQualityPreset}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Margin="0,0,0,4"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="{Binding ThreeDIntensityOptionLabel}" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding ThreeDIntensityOptions}"
                                                          SelectedValue="{Binding SelectedThreeDIntensity}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Margin="0,0,0,4"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="{Binding ThreeDOutputFormatOptionLabel}" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding ThreeDOutputFormatOptions}"
                                                          SelectedValue="{Binding SelectedThreeDOutputFormat}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Margin="0,0,0,4"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding LocalModelSelectionLabel}" />
                                            <ComboBox DisplayMemberPath="DisplayName"
                                                      IsEnabled="{Binding HasLocalModelSelectionCandidates}"
                                                      ItemsSource="{Binding LocalModelCandidates}"
                                                      SelectedItem="{Binding SelectedLocalModelCandidate,
                                                                             Mode=TwoWay}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding LocalModelSelectionStatusText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border Margin="0,10,0,0"
                                                Padding="10"
                                                Background="{DynamicResource InputBackgroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Visibility="{Binding LgCompatibilityOptionsVisibility}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding LgCompatibilityCopyExplanationText}"
                                                           TextWrapping="Wrap" />
                                                <CheckBox Content="{Binding CreateLgCompatibilityCopyText}"
                                                          IsChecked="{Binding CreateLgCompatibilityCopy,
                                                                              Mode=TwoWay}"
                                                          IsEnabled="{Binding CanChangeLgCompatibilityCopyOptions}" />
                                                <CheckBox Margin="0,6,0,0"
                                                          Content="{Binding PreferLgCompatibilityCopyWhenOpeningText}"
                                                          IsChecked="{Binding PreferLgCompatibilityCopyWhenOpening,
                                                                              Mode=TwoWay}"
                                                          IsEnabled="{Binding CanPreferLgCompatibilityCopyWhenOpening}" />
                                            </StackPanel>
                                        </Border>
                                        <CheckBox Margin="0,10,0,0"
                                                  Content="{Binding OpenOutputWhenFinishedText}"
                                                  IsChecked="{Binding OpenOutputWhenFinished,
                                                                      Mode=TwoWay}"
                                                  IsEnabled="{Binding CanChangeOpenOutputWhenFinished}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding OutputLocationTitle}" />
                                        <TextBlock Margin="0,0,0,4"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding OutputPathLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding OutputPathText}" />
                                            <Button Grid.Column="2"
                                                    Padding="10,5"
                                                    Command="{Binding BrowseOutputFolderCommand}"
                                                    Content="{Binding BrowseOutputFolderText}" />
                                            <Button Grid.Column="4"
                                                    Padding="10,5"
                                                    Command="{Binding ResetOutputPathCommand}"
                                                    Content="{Binding ResetOutputPathText}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="0,0,0,8"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding ConversionPlanStatusText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Text="{Binding ConversionPlanPresetText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ConversionPlanLocalModelText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConversionPlanOutputPathText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConversionPlanLgCompatibilityCopyPathText}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding LgCompatibilityCopyPathVisibility}" />
                                <TextBlock Text="{Binding ConversionPlanOutputFormatText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConversionPlanResolutionText}" />
                                <TextBlock Text="{Binding ConversionPlanThreeDLayoutText}" />
                                <TextBlock Text="{Binding ConversionPlanQualityText}" />
                                <TextBlock Text="{Binding ConversionPlanIntensityText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ConversionPlanDryRunReasonText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding ConversionPlanStepsTitle}" />
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ConversionPlanStepsText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding ConversionPlanCommandPreviewTitle}" />
                                <Border Padding="8"
                                        Background="{DynamicResource LogBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding ConversionPlanCommandPreviewText}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>

                </Grid>
            </ScrollViewer>

            <Border Margin="0,0,4,0"
                    Style="{StaticResource CardStyle}"
                    Visibility="{Binding ConversionRunningVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding ConversionRunningTitle}" />
                    <StackPanel Grid.Row="1">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding ConversionRunningStatusText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding ConversionExecutionDetailText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ListBox x:Name="ConversionLiveLogList"
                             Grid.Row="3"
                             Padding="10"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             ItemsSource="{Binding ConversionLogs}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Resources>
                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="2" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding DisplayText}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        ClipToBounds="True"
                        Margin="0,0,0,6"
                        Style="{StaticResource CardStyle}">
                    <Grid ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding SystemStatusTitle}" />
                            <StackPanel Grid.Column="1"
                                        Margin="0,0,0,8"
                                        Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        AutomationProperties.AutomationId="ShowTechnicalDetailsButton"
                                        Command="{Binding ShowTechnicalDetailsCommand}"
                                        Content="{Binding SystemStatusDetailsButtonText}"
                                        IsEnabled="{Binding CanUseSystemStatusActions}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Padding="10,5"
                                        Command="{Binding RefreshEngineStatusCommand}"
                                        Content="{Binding RefreshText}"
                                        IsEnabled="{Binding CanUseSystemStatusActions}" />
                            </StackPanel>
                        </Grid>
                        <TabControl Grid.Row="1"
                                    SelectedIndex="{Binding SelectedSystemStatusTabIndex,
                                                            Mode=TwoWay}"
                                    Style="{StaticResource WorkflowTabControlStyle}">
                            <TabItem Header="{Binding SystemStatusToolsTabTitle}"
                                     IsEnabled="{Binding CanOpenSystemStatusToolsTab}"
                                     Style="{StaticResource WorkflowTabItemStyle}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                               TargetType="ScrollBar" />
                                    </ScrollViewer.Resources>
                                    <ItemsControl ItemsSource="{Binding ToolStatuses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ToolTip>
                                                        <ToolTip>
                                                            <TextBlock MaxWidth="480"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       Text="{Binding PlacementTarget.DataContext.DetailText,
                                                                                      RelativeSource={RelativeSource AncestorType=ToolTip}}"
                                                                       TextWrapping="Wrap" />
                                                        </ToolTip>
                                                    </Grid.ToolTip>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               HorizontalAlignment="Right"
                                                               TextAlignment="Right"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding StatusText}" />
                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Text="{Binding ReasonText}"
                                                               TextWrapping="Wrap" />
                                                    <Button Grid.Row="1"
                                                               Grid.Column="1"
                                                               MinWidth="52"
                                                               Margin="8,2,0,0"
                                                               Padding="8,3"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Top"
                                                               Command="{Binding DataContext.OpenEngineFolderCommand,
                                                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                                               Content="{Binding ContextActionText}"
                                                               Style="{StaticResource SecondaryButtonStyle}"
                                                               ToolTip="{Binding ContextActionToolTip}"
                                                               Visibility="{Binding ContextActionVisibility}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="{Binding SystemStatusConversionTabTitle}"
                                     IsEnabled="{Binding CanOpenSystemStatusConversionTab}"
                                     Style="{StaticResource WorkflowTabItemStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Resources>
                                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                                   TargetType="ScrollBar" />
                                        </ScrollViewer.Resources>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ConversionReadinessStatusLabel}"
                                                       Style="{StaticResource MutedTextStyle}" />
                                            <TextBlock Margin="0,2,0,8"
                                                       Text="{Binding ConversionReadinessStatusText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ConversionReadinessMissingRequirementsTitle}"
                                                       Style="{StaticResource MutedTextStyle}" />
                                            <TextBlock Margin="0,2,0,8"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding ConversionReadinessMissingComponentsSummaryText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,0,0,10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding ConversionReadinessRequiredComponentsText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,0,0,10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding ConversionBlockedReasonText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Button HorizontalAlignment="Stretch"
                                            Grid.Row="1"
                                            Margin="0,10,0,0"
                                            AutomationProperties.AutomationId="StartConversionButton"
                                            Command="{Binding StartConversionCommand}"
                                            Content="{Binding StartConversionText}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource PrimaryCtaButtonStyle}"
                                                   TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversionRunning}"
                                                                 Value="True">
                                                        <Setter Property="Background" Value="#B91C1C" />
                                                        <Setter Property="BorderBrush" Value="#B91C1C" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        ClipToBounds="True"
                        Margin="0,6,0,0"
                        Style="{StaticResource CardStyle}"
                        Visibility="{Binding ActivityLogVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding ActivityLogTitle}" />
                            <Button Grid.Column="1"
                                    Margin="0,0,0,8"
                                    Padding="10,5"
                                    Command="{Binding ClearLogsCommand}"
                                    Content="{Binding ClearText}" />
                        </Grid>
                        <ListBox Grid.Row="1"
                                 Padding="8"
                                 Background="{DynamicResource LogBackgroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 ItemsSource="{Binding Logs}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Width" Value="Auto" />
                                            <Setter Property="MinWidth" Value="0" />
                                            <Setter Property="Height" Value="10" />
                                            <Setter Property="MinHeight" Value="10" />
                                            <Setter Property="Template"
                                                    Value="{StaticResource ModernHorizontalScrollBarTemplate}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource PrimaryTextBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="2" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding DisplayText}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        ClipToBounds="True"
                        Margin="0,6,0,0"
                        Style="{StaticResource CardStyle}"
                        Visibility="{Binding ConversionSummaryVisibility}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </ScrollViewer.Resources>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding ConversionSummaryTitle}" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding ConversionRunningStatusText}" />
                            <TextBlock Text="{Binding ConversionSummaryPresetText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryOutputContainerText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryQualityText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryIntensityText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryLayoutText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryLocalModelText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryOutputPathText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryLgCompatibilityCopyText}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding LgCompatibilityCopyPathVisibility}" />
                            <CheckBox Margin="0,10,0,0"
                                      Content="{Binding OpenOutputWhenFinishedText}"
                                      IsChecked="{Binding OpenOutputWhenFinished,
                                                          Mode=TwoWay}"
                                      IsEnabled="{Binding CanChangeOpenOutputWhenFinished}" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding ConversionSummaryCurrentStatusText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding CpuUsageText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RamUsageText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding GpuUsageText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding VramUsageText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="10"
              Style="{StaticResource V3dfyModalOverlayStyle}"
              Visibility="{Binding ModalOverlayVisibility}">
            <Border Width="680"
                    MaxHeight="520"
                    MinHeight="360"
                    Margin="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource V3dfyModalCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource V3dfyModalTitleTextStyle}"
                               Text="{Binding ActiveModalTitleText}" />

                    <TextBox Grid.Row="1"
                             MinHeight="220"
                             AcceptsReturn="True"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             Text="{Binding TechnicalDetailsBodyText, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding TechnicalDetailsModalContentVisibility}">
                        <TextBox.Resources>
                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </TextBox.Resources>
                    </TextBox>

                    <TextBox Grid.Row="1"
                             MinHeight="220"
                             AcceptsReturn="True"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             Text="{Binding ProfileDetailsBodyText, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding ProfileDetailsModalContentVisibility}">
                        <TextBox.Resources>
                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Grid.Row="1"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding ReplaceSelectedVideoBodyText}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />

                    <StackPanel Grid.Row="3"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button AutomationProperties.AutomationId="CancelReplaceVideoButton"
                                Command="{Binding CancelReplaceVideoCommand}"
                                Content="{Binding CancelDialogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="ConfirmReplaceVideoButton"
                                Command="{Binding ConfirmReplaceVideoCommand}"
                                Content="{Binding ReplaceVideoConfirmText}"
                                Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CloseTechnicalDetailsButton"
                                Command="{Binding CloseTechnicalDetailsCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding TechnicalDetailsModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CloseProfileDetailsButton"
                                Command="{Binding CloseProfileDetailsCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding ProfileDetailsModalContentVisibility}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
