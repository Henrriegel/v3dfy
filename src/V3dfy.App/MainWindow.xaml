                                    Margin="16,0,0,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Visibility="{Binding PreviewMetricsHeaderVisibility}">
                            <TextBlock Margin="0,0,10,0"
                                       Text="{Binding PreviewCpuUsageText}" />
                            <TextBlock Margin="0,0,10,0"
                                       Text="{Binding PreviewRamUsageText}" />
                            <TextBlock Margin="0,0,10,0"
                                       Text="{Binding PreviewGpuUsageText}" />
                            <TextBlock Text="{Binding PreviewVramUsageText}" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="SettingsModalHorizontalViewport"
                                  Grid.Row="1"
                                  AutomationProperties.AutomationId="SettingsModal"
                                  Style="{StaticResource ResponsiveHorizontalViewportScrollViewerStyle}"
                                  Visibility="{Binding SettingsModalContentVisibility}">
                        <Grid MinWidth="620"
                              AutomationProperties.AutomationId="SettingsModalContentGrid"
                              Width="{Binding ViewportWidth, ElementName=SettingsModalHorizontalViewport}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"
                                              MinWidth="200" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*"
                                              MinWidth="380" />
                        </Grid.ColumnDefinitions>
                        <Border MinWidth="200"
                                Padding="10"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Text="{Binding SettingsSideMenuTitleText}" />
                                <ListBox AutomationProperties.AutomationId="SettingsSideMenu"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         DisplayMemberPath="DisplayName"
                                         ItemsSource="{Binding SettingsSectionOptions}"
                                         ItemContainerStyle="{StaticResource SettingsMenuListBoxItemStyle}"
                                         SelectedValue="{Binding SelectedSettingsSection,
                                                                 Mode=TwoWay}"
                                         SelectedValuePath="Value" />
                            </DockPanel>
                        </Border>
                        <ScrollViewer Grid.Column="2"
                                      MinWidth="380"
                                      Style="{StaticResource ResponsiveModalBodyScrollViewerStyle}">
                            <Grid>
                                <StackPanel AutomationProperties.AutomationId="VisualSettingsSection"
                                            Visibility="{Binding VisualSettingsSectionVisibility}">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="{Binding VisualSettingsTitleText}" />
                                    <StackPanel AutomationProperties.AutomationId="VisualSettingsRows">
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Margin="0,0,0,4"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding LanguageLabel}" />
                                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                      SelectedItem="{Binding SelectedLanguage}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,4"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding ThemeLabel}" />
                                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                      SelectedItem="{Binding SelectedTheme}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel AutomationProperties.AutomationId="ModelsSettingsSection"
                                            Visibility="{Binding ModelsSettingsSectionVisibility}">
                                    <Grid AutomationProperties.AutomationId="ModelsSettingsHeader"
                                          Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                                   Text="{Binding ModelsSettingsTitleText}" />
                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal">
                                            <Button AutomationProperties.AutomationId="SettingsViewModelsButton"
                                                    Command="{Binding ShowModelInventoryCommand}"
                                                    Content="{Binding ViewModelsText}"
                                                    IsEnabled="{Binding CanUseSettingsSystemStatusActions}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Margin="0,0,0,12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding ModelsSettingsIntroText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding SelectableModelsSectionTitleText}" />
                                    <Border Margin="0,6,0,10"
                                            MinHeight="116"
                                            MaxHeight="220"
                                            AutomationProperties.AutomationId="SettingsSelectableModelsTable"
                                            Style="{StaticResource ResponsiveTableContainerStyle}"
                                            Visibility="{Binding SettingsSelectableModelsTableVisibility}">
                                        <ScrollViewer x:Name="SettingsSelectableModelsTableViewport"
                                                      Style="{StaticResource ResponsiveTableHorizontalScrollViewerStyle}">
                                        <Grid MinWidth="660"
                                              Width="{Binding ViewportWidth, ElementName=SettingsSelectableModelsTableViewport}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Style="{StaticResource TableHeaderBorderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.3*" />
                                                        <ColumnDefinition Width="0.9*" />
                                                        <ColumnDefinition Width="1.8*" />
                                                        <ColumnDefinition Width="0.75*" />
                                                        <ColumnDefinition Width="0.9*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelNameHeaderText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelIw3HeaderText}"
