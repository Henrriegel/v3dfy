<Window x:Class="V3dfy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:V3dfy.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Icon="Assets/Branding/v3dfy.ico"
        Width="1120"
        Height="800"
        MinWidth="920"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        Drop="OnDrop"
        ResizeMode="CanResize"
        StateChanged="OnWindowStateChanged"
        WindowStyle="SingleBorderWindow">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:ViewportMaxSizeConverter x:Key="ViewportMaxSizeConverter" />
        <converters:ViewportThresholdVisibilityConverter x:Key="ViewportThresholdVisibilityConverter" />
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="TableHeaderBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="StripedTableRowBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=(ItemsControl.AlternationIndex),
                                               RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                             Value="1">
                    <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TechnicalLogScrollBarStyle"
               BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
               TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="10" />
                    <Setter Property="MinHeight" Value="10" />
                    <Setter Property="Template"
                            Value="{StaticResource ModernHorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ResponsiveHorizontalViewportScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Style.Resources>
                <Style BasedOn="{StaticResource TechnicalLogScrollBarStyle}"
                       TargetType="ScrollBar" />
            </Style.Resources>
        </Style>
        <Style x:Key="ResponsiveTableHorizontalScrollViewerStyle"
               BasedOn="{StaticResource ResponsiveHorizontalViewportScrollViewerStyle}"
               TargetType="ScrollViewer" />
        <Style x:Key="ResponsiveModalFooterWrapPanelStyle" TargetType="WrapPanel">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>
        <Style x:Key="ResponsiveLogHeaderButtonStyle"
               BasedOn="{StaticResource SecondaryButtonStyle}"
               TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
        <Style x:Key="TitleBarWindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleBarButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ComboBoxHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitleBarMaximizeRestoreButtonStyle"
               BasedOn="{StaticResource TitleBarWindowButtonStyle}"
               TargetType="Button">
            <Setter Property="AutomationProperties.Name" Value="{Binding WindowMaximizeToolTipText}" />
            <Setter Property="ToolTip" Value="{Binding WindowMaximizeToolTipText}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WindowState,
                                               RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="Maximized">
                    <Setter Property="AutomationProperties.Name" Value="{Binding WindowRestoreToolTipText}" />
                    <Setter Property="ToolTip" Value="{Binding WindowRestoreToolTipText}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitleBarMaximizeRestoreGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Text" Value="&#xE922;" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WindowState,
                                               RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="Maximized">
                    <Setter Property="Text" Value="&#xE923;" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="AutomationProperties.Name" Value="{Binding WindowCloseToolTipText}" />
            <Setter Property="ToolTip" Value="{Binding WindowCloseToolTipText}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleBarCloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DestructiveBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DestructivePressedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DestructiveBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WizardStepPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Opacity" Value="0.72" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Completed">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Locked">
                    <Setter Property="Opacity" Value="0.48" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WizardStepMarkerStyle" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="Active">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="Completed">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImageWizardStepButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          TextElement.Foreground="{DynamicResource PrimaryTextBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WizardFooterButtonStyle"
               BasedOn="{StaticResource {x:Type Button}}"
               TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinWidth" Value="88" />
        </Style>
        <Style x:Key="WizardFooterSecondaryButtonStyle"
               BasedOn="{StaticResource SecondaryButtonStyle}"
               TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinWidth" Value="88" />
        </Style>
        <Style x:Key="ShellSidebarNavButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ShellNavButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShellNavButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ShellNavButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource InputBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarToggleStripButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SidebarToggleStripBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SidebarToggleStripBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SidebarToggleStripBorder"
                                        Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HomeActionCardButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="172" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HomeActionCardBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HomeActionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="HomeActionCardBorder"
                                        Property="Background"
                                        Value="{DynamicResource InputBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HomeActionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ImageWorkflowOptionCardButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="172" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ImageWorkflowOptionCardBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                         Value="Active">
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="Background"
                                        Value="{DynamicResource TabSelectedBackgroundBrush}" />
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderThickness"
                                        Value="2" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               Value="Active" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}"
                                               Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentHoverBrush}" />
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderThickness"
                                        Value="2" />
                            </MultiDataTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ImageWorkflowOptionCardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ImageWorkflowSelectedMarkerStyle" TargetType="Border">
            <Setter Property="Height" Value="4" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImageWorkflowOptionIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImageWorkflowOptionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImageWorkflowSelectionBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource ButtonForegroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShellSidebarIconTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style x:Key="SettingsMenuListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{DynamicResource InputBackgroundBrush}" />
                                <Setter TargetName="ItemBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="V3dfyExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          DockPanel.Dock="Top"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded,
                                                              RelativeSource={RelativeSource TemplatedParent},
                                                              Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderBorder"
                                                Padding="10,8"
                                                Background="{DynamicResource InputBackgroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="22"
                                                        Height="22"
                                                        Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="11">
                                                    <TextBlock x:Name="Chevron"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               Text=">" />
                                                </Border>
                                                <ContentPresenter Grid.Column="1"
                                                                  Margin="8,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  Content="{TemplateBinding Content}"
                                                                  RecognizesAccessKey="True"
                                                                  TextElement.Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderBorder"
                                                        Property="BorderBrush"
                                                        Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="HeaderBorder"
                                                        Property="BorderBrush"
                                                        Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="Chevron"
                                                        Property="Text"
                                                        Value="v" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header" />
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="0,8,0,0"
                                              ContentSource="Content"
                                              Visibility="Collapsed" />
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="AppChromeRoot"
          Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn"
                              Width="208"
                              MinWidth="64" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              AutomationProperties.AutomationId="AppTitleBar"
              Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border AutomationProperties.AutomationId="AppTitleBarCaptionArea"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="0,0,0,1" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeWindowButton"
                        AutomationProperties.AutomationId="TitleBarMinimizeButton"
                        AutomationProperties.Name="{Binding WindowMinimizeToolTipText}"
                        Click="OnMinimizeWindowButtonClick"
                        Content="&#xE921;"
                        Style="{StaticResource TitleBarWindowButtonStyle}"
                        ToolTip="{Binding WindowMinimizeToolTipText}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button x:Name="MaximizeRestoreWindowButton"
                        AutomationProperties.AutomationId="TitleBarMaximizeRestoreButton"
                        Click="OnMaximizeRestoreWindowButtonClick"
                        Style="{StaticResource TitleBarMaximizeRestoreButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Style="{StaticResource TitleBarMaximizeRestoreGlyphStyle}" />
                </Button>
                <Button x:Name="CloseWindowButton"
                        AutomationProperties.AutomationId="TitleBarCloseButton"
                        Click="OnCloseWindowButtonClick"
                        Content="&#xE8BB;"
                        Style="{StaticResource TitleBarCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="0"
                Grid.Row="1"
                Padding="{Binding SidebarPadding}"
                AutomationProperties.AutomationId="AppSidebar"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,1,0"
                MouseEnter="OnSidebarMouseEnter"
                MouseLeave="OnSidebarMouseLeave"
                ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel AutomationProperties.AutomationId="SidebarBrand"
                            HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                            Orientation="Horizontal">
                    <Image Width="34"
                           Height="34"
                           HorizontalAlignment="Center"
                           Source="Assets/Branding/v3dfy-icon-left-square-transparent.png"
                           Stretch="Uniform" />
                    <StackPanel Margin="10,0,8,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding SidebarExpandedContentVisibility}">
                        <TextBlock FontSize="21"
                                   FontWeight="Bold"
                                   Text="{Binding AppTitle}" />
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding ShellTaglineText}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,28,0,0"
                            AutomationProperties.AutomationId="SidebarNavigation">
                    <Button AutomationProperties.AutomationId="SidebarHomeButton"
                            AutomationProperties.Name="{Binding HomeNavigationText}"
                            Command="{Binding SelectHomeSectionCommand}"
                            IsEnabled="{Binding CanUseShellNavigation}"
                            Style="{StaticResource ShellSidebarNavButtonStyle}"
                            Tag="{Binding IsHomeSectionSelected}"
                            ToolTip="{Binding HomeNavigationText}"
                            ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
                        <StackPanel HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ShellSidebarIconTextStyle}"
                                       Text="&#xE80F;" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding HomeNavigationText}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding SidebarExpandedContentVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.AutomationId="SidebarImageConversionButton"
                            AutomationProperties.Name="{Binding ImageConversionNavigationText}"
                            Command="{Binding SelectImageConversionSectionCommand}"
                            IsEnabled="{Binding CanUseShellNavigation}"
                            Style="{StaticResource ShellSidebarNavButtonStyle}"
                            Tag="{Binding IsImageConversionSectionSelected}"
                            ToolTip="{Binding ImageConversionNavigationText}"
                            ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
                        <StackPanel HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ShellSidebarIconTextStyle}"
                                       Text="&#xEB9F;" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding ImageConversionNavigationText}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding SidebarExpandedContentVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.AutomationId="SidebarVideoConversionButton"
                            AutomationProperties.Name="{Binding VideoConversionNavigationText}"
                            Command="{Binding SelectVideoConversionSectionCommand}"
                            IsEnabled="{Binding CanUseShellNavigation}"
                            Style="{StaticResource ShellSidebarNavButtonStyle}"
                            Tag="{Binding IsVideoConversionSectionSelected}"
                            ToolTip="{Binding VideoConversionNavigationText}"
                            ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
                        <StackPanel HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ShellSidebarIconTextStyle}"
                                       Text="&#xE714;" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding VideoConversionNavigationText}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding SidebarExpandedContentVisibility}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            AutomationProperties.AutomationId="SidebarBottomActions">
                    <Button AutomationProperties.AutomationId="SidebarToggleStripButton"
                            AutomationProperties.Name="{Binding SidebarToggleToolTipText}"
                            Command="{Binding ToggleSidebarCommand}"
                            IsEnabled="{Binding CanUseShellNavigation}"
                            Style="{StaticResource SidebarToggleStripButtonStyle}"
                            ToolTip="{Binding SidebarToggleToolTipText}"
                            ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
                        <StackPanel HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ShellSidebarIconTextStyle}"
                                       Text="{Binding SidebarToggleGlyphText}" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding SidebarToggleText}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding SidebarExpandedContentVisibility}" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,8,0,0"
                            AutomationProperties.AutomationId="SidebarSettingsButton"
                            AutomationProperties.Name="{Binding SettingsText}"
                            Command="{Binding OpenSettingsCommand}"
                            IsEnabled="{Binding CanOpenSettings}"
                            Style="{StaticResource ShellSidebarNavButtonStyle}"
                            ToolTip="{Binding SettingsText}"
                            ToolTipService.IsEnabled="{Binding ShellToolTipsEnabled}">
                        <StackPanel HorizontalAlignment="{Binding SidebarNavContentHorizontalAlignment}"
                                    Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ShellSidebarIconTextStyle}"
                                       Text="&#xE713;" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding SettingsText}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding SidebarExpandedContentVisibility}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Grid.Row="1"
              Margin="24"
              Background="{DynamicResource WindowBackgroundBrush}">
            <ScrollViewer AutomationProperties.AutomationId="HomeSection"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HomeSectionVisibility}">
                <ScrollViewer.Resources>
                    <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                           TargetType="ScrollBar" />
                </ScrollViewer.Resources>
                <StackPanel MaxWidth="1040">
                    <Border Padding="20"
                            AutomationProperties.AutomationId="HomeOverviewPanel"
                            Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="26"
                                           FontWeight="Bold"
                                           Text="{Binding HomeTitleText}" />
                                <TextBlock Margin="0,8,0,14"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding HomeDescriptionText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HomeStatusSummaryText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="28"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="&#xE946;" />
                                    <TextBlock Margin="0,10,0,4"
                                               FontWeight="SemiBold"
                                               Text="{Binding HomeLocalOnlyBadgeText}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding HomeVideoStatusText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding HomeImageStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <UniformGrid Margin="0,18,0,0"
                                 Columns="3"
                                 AutomationProperties.AutomationId="HomeQuickCards">
                        <Button Margin="0,0,12,0"
                                AutomationProperties.AutomationId="HomeVideoConversionCard"
                                Command="{Binding SelectVideoConversionSectionCommand}"
                                IsEnabled="{Binding CanUseShellNavigation}"
                                Style="{StaticResource HomeActionCardButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="30"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="&#xE714;" />
                                <StackPanel Grid.Row="1"
                                            Margin="0,12,0,12">
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="{Binding HomeVideoCardTitleText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding HomeVideoCardBodyText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid Grid.Row="2">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="{Binding ReadyNowText}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Text="{Binding OpenSectionText}" />
                                </Grid>
                            </Grid>
                        </Button>
                        <Button Margin="0,0,12,0"
                                AutomationProperties.AutomationId="HomeImageConversionCard"
                                Command="{Binding SelectImageConversionSectionCommand}"
                                IsEnabled="{Binding CanUseShellNavigation}"
                                Style="{StaticResource HomeActionCardButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="30"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="&#xEB9F;" />
                                <StackPanel Grid.Row="1"
                                            Margin="0,12,0,12">
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="{Binding HomeImageCardTitleText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding HomeImageCardBodyText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid Grid.Row="2">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding ComingNextText}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Text="{Binding OpenSectionText}" />
                                </Grid>
                            </Grid>
                        </Button>
                        <Button AutomationProperties.AutomationId="HomeSettingsCard"
                                Command="{Binding OpenSettingsCommand}"
                                IsEnabled="{Binding CanOpenSettings}"
                                Style="{StaticResource HomeActionCardButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="30"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="&#xE713;" />
                                <StackPanel Grid.Row="1"
                                            Margin="0,12,0,12">
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="{Binding HomeSettingsCardTitleText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding HomeSettingsCardBodyText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid Grid.Row="2">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="{Binding HomeModelsStatusText}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Text="{Binding SettingsText}" />
                                </Grid>
                            </Grid>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>

            <Grid AutomationProperties.AutomationId="ImageConversionSection"
                  Visibility="{Binding ImageConversionSectionVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,4,0"
                        AutomationProperties.AutomationId="ImageConversionWizard"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,14"
                              AutomationProperties.AutomationId="ImageConversionStepper">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Tag="{Binding ImageModeSourceStepState}"
                                    Style="{StaticResource WizardStepPillStyle}">
                                <Button Command="{Binding SelectImageModeSourceStepCommand}"
                                        IsEnabled="{Binding CanUseImageStepNavigation}"
                                        Style="{StaticResource ImageWizardStepButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Tag="{Binding ImageModeSourceStepState}"
                                                Style="{StaticResource WizardStepMarkerStyle}">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource ButtonForegroundBrush}"
                                                       Text="{Binding ImageModeSourceStepMarkerText}" />
                                        </Border>
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ImageModeSourceStepTitleText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border Grid.Column="2"
                                    Tag="{Binding ImageSetupStepState}"
                                    Style="{StaticResource WizardStepPillStyle}">
                                <Button Command="{Binding SelectImageSetupStepCommand}"
                                        IsEnabled="{Binding CanUseImageStepNavigation}"
                                        Style="{StaticResource ImageWizardStepButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Tag="{Binding ImageSetupStepState}"
                                                Style="{StaticResource WizardStepMarkerStyle}">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource ButtonForegroundBrush}"
                                                       Text="{Binding ImageSetupStepMarkerText}" />
                                        </Border>
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ImageSetupStepTitleText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border Grid.Column="4"
                                    Tag="{Binding ImagePreviewExportStepState}"
                                    Style="{StaticResource WizardStepPillStyle}">
                                <Button Command="{Binding SelectImagePreviewExportStepCommand}"
                                        IsEnabled="{Binding CanUseImageStepNavigation}"
                                        Style="{StaticResource ImageWizardStepButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Tag="{Binding ImagePreviewExportStepState}"
                                                Style="{StaticResource WizardStepMarkerStyle}">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource ButtonForegroundBrush}"
                                                       Text="{Binding ImagePreviewExportStepMarkerText}" />
                                        </Border>
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ImagePreviewExportStepTitleText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar" />
                            </ScrollViewer.Resources>
                            <Grid Margin="0,0,8,0">
                                <StackPanel AutomationProperties.AutomationId="ImageModeSourceStepContent"
                                            Visibility="{Binding ImageModeSourceStepVisibility}">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="{Binding ImageSourceAnalysisTitleText}" />
                                    <Border AutomationProperties.AutomationId="ImageSourceSelectionPanel"
                                            Padding="16"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding DropImageText}" />
                                            <TextBlock Margin="0,6,0,12"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding ImageSupportedExtensionsText}" />
                                            <TextBlock Margin="0,0,0,12"
                                                       Text="{Binding SelectedImageDisplayPath}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal">
                                                <Button AutomationProperties.AutomationId="SelectImageButton"
                                                        Command="{Binding SelectImageCommand}"
                                                        Content="{Binding SelectImageText}"
                                                        IsEnabled="{Binding CanInteractWithImageWorkflow}" />
                                                <Button Margin="10,0,0,0"
                                                        AutomationProperties.AutomationId="AnalyzeImageButton"
                                                        Command="{Binding AnalyzeImageCommand}"
                                                        Content="{Binding AnalyzeImageText}"
                                                        IsEnabled="{Binding CanAnalyzeImage}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,12,0,14"
                                            AutomationProperties.AutomationId="ImageMetadataPanel"
                                            Style="{StaticResource CardStyle}"
                                            Visibility="{Binding ImageAnalysisResultsVisibility}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding ImageAnalysisTitleText}" />
                                            <UniformGrid Margin="0,8,0,0"
                                                         Columns="2">
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataWidthText}" />
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataHeightText}" />
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataAspectRatioText}" />
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataFormatText}" />
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataPixelFormatText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,0,12,6"
                                                           Text="{Binding ImageMetadataFileSizeText}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel AutomationProperties.AutomationId="ImageSetupStepContent"
                                            Visibility="{Binding ImageSetupStepVisibility}">
                                    <Border x:Name="ImageWorkflowSummaryBar"
                                            AutomationProperties.AutomationId="ImageWorkflowSummaryBar"
                                            Padding="10"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Visibility="{Binding ImageWorkflowSummaryVisibility}">
                                        <StackPanel>
                                            <Grid AutomationProperties.AutomationId="ImageWorkflowSummaryWideLayout"
                                                  Visibility="{Binding ActualWidth,
                                                                       ElementName=ImageWorkflowSummaryBar,
                                                                       Converter={StaticResource ViewportThresholdVisibilityConverter},
                                                                       ConverterParameter=GreaterOrEqual:360}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding ImageWorkflowSummaryText}"
                                                           TextWrapping="Wrap" />
                                                <Button Grid.Column="1"
                                                        Margin="12,0,0,0"
                                                        Padding="10,5"
                                                        AutomationProperties.AutomationId="ChangeImageWorkflowButton"
                                                        Command="{Binding ToggleImageWorkflowChooserCommand}"
                                                        IsEnabled="{Binding CanInteractWithImageWorkflow}"
                                                        Style="{StaticResource SecondaryButtonStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ChangeImageWorkflowText}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="8,0,0,0"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   Text="{Binding ImageWorkflowChooserChevronText}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <StackPanel AutomationProperties.AutomationId="ImageWorkflowSummaryNarrowLayout"
                                                        Visibility="{Binding ActualWidth,
                                                                             ElementName=ImageWorkflowSummaryBar,
                                                                             Converter={StaticResource ViewportThresholdVisibilityConverter},
                                                                             ConverterParameter=LessThan:360}">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding ImageWorkflowSummaryText}"
                                                           TextWrapping="Wrap" />
                                                <Button Margin="0,8,0,0"
                                                        Padding="10,5"
                                                        HorizontalAlignment="Stretch"
                                                        AutomationProperties.AutomationId="ChangeImageWorkflowButtonNarrow"
                                                        Command="{Binding ToggleImageWorkflowChooserCommand}"
                                                        IsEnabled="{Binding CanInteractWithImageWorkflow}"
                                                        Style="{StaticResource SecondaryButtonStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ChangeImageWorkflowText}"
