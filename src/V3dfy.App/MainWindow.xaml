                                       ElementName=ModalOverlay,
                                       Converter={StaticResource ViewportMaxSizeConverter},
                                       ConverterParameter=48}"
                    MaxHeight="{Binding ActualHeight,
                                        ElementName=ModalOverlay,
                                        Converter={StaticResource ViewportMaxSizeConverter},
                                        ConverterParameter=48}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource ResponsiveModalCardStyle}">
