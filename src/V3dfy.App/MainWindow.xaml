                            <Grid Margin="0,0,0,4">
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ConversionExecutionProgressLabel}" />
                                <TextBlock HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Text="{Binding PreviewProgressText}" />
                            </Grid>
                            <ProgressBar Maximum="100"
                                         IsIndeterminate="{Binding PreviewProgressIsIndeterminate}"
                                         Value="{Binding PreviewProgressPercent, Mode=OneWay}"
                                         Style="{StaticResource V3dfyProgressBarStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Row="5"
                                    Margin="0,8,0,0">
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding PreviewEngineText}"
                                       ToolTip="{Binding PreviewRunningWithText}"
                                       TextWrapping="Wrap" />
