                            <TextBlock Text="{Binding ConversionSummaryOutputContainerText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryQualityText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryIntensityText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryLayoutText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryLocalModelText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ConversionSummaryOutputPathText}"
