                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Style="{StaticResource TableHeaderBorderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.3*" />
                                                        <ColumnDefinition Width="0.9*" />
                                                        <ColumnDefinition Width="1.8*" />
                                                        <ColumnDefinition Width="0.75*" />
                                                        <ColumnDefinition Width="0.9*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelNameHeaderText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelIw3HeaderText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="2"
                                                               Margin="8,0,0,0"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelCheckpointHeaderText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="3"
                                                               Margin="8,0,0,0"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelTypeHeaderText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="4"
                                                               Margin="8,0,0,0"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectableModelSourceHeaderText}"
                                                               TextWrapping="Wrap" />
                                                </Grid>
                                            </Border>
                                            <ScrollViewer Grid.Row="1"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ScrollViewer.Resources>
                                                    <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                                           TargetType="ScrollBar" />
                                                </ScrollViewer.Resources>
                                                <ItemsControl AlternationCount="2"
                                                              ItemsSource="{Binding SelectableModelInventoryRows}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource StripedTableRowBorderStyle}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="1.3*" />
                                                                        <ColumnDefinition Width="0.9*" />
                                                                        <ColumnDefinition Width="1.8*" />
                                                                        <ColumnDefinition Width="0.75*" />
                                                                        <ColumnDefinition Width="0.9*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Model}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="8,0,0,0"
                                                                               Text="{Binding Iw3DepthModel}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="2"
                                                                               Margin="8,0,0,0"
                                                                               Text="{Binding Checkpoint}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="3"
                                                                               Margin="8,0,0,0"
                                                                               Text="{Binding Type}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="4"
                                                                               Margin="8,0,0,0"
                                                                               Text="{Binding Source}"
                                                                               TextWrapping="Wrap" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                    <TextBlock Margin="0,6,0,10"
                                               AutomationProperties.AutomationId="SettingsSelectableModelsEmptyState"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding SettingsSelectableModelsEmptyText}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding SettingsSelectableModelsEmptyVisibility}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding ModelPackImportStatusText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding LastModelPackImportSummary}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding LastModelPackImportSummaryVisibility}" />
                                </StackPanel>

                                <StackPanel AutomationProperties.AutomationId="ToolsEngineSettingsSection"
                                            Visibility="{Binding ToolsEngineSettingsSectionVisibility}">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                                   Text="{Binding ToolsEngineSettingsTitleText}" />
                                        <Button Grid.Column="1"
                                                Padding="10,5"
                                                AutomationProperties.AutomationId="SettingsRefreshToolsButton"
                                                Command="{Binding RefreshEngineStatusCommand}"
                                                Content="{Binding RefreshText}"
                                                IsEnabled="{Binding CanUseSystemStatusActions}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>
                                    <TextBlock Margin="0,0,0,12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding ToolsEngineSettingsIntroText}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ToolStatuses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ToolTip>
                                                        <ToolTip>
                                                            <TextBlock MaxWidth="480"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       Text="{Binding PlacementTarget.DataContext.DetailText,
                                                                                      RelativeSource={RelativeSource AncestorType=ToolTip}}"
                                                                       TextWrapping="Wrap" />
                                                        </ToolTip>
                                                    </Grid.ToolTip>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               MinWidth="80"
                                                               HorizontalAlignment="Right"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Right"
                                                               Text="{Binding StatusText}" />
                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Text="{Binding ReasonText}"
                                                               TextWrapping="Wrap" />
                                                    <Button Grid.Row="1"
                                                            Grid.Column="1"
                                                            MinWidth="52"
                                                            Margin="8,2,0,0"
                                                            Padding="8,3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Command="{Binding ContextActionCommand}"
                                                            Content="{Binding ContextActionText}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            ToolTip="{Binding ContextActionToolTip}"
                                                            Visibility="{Binding ContextActionVisibility}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel AutomationProperties.AutomationId="LogsDiagnosticsSettingsSection"
                                            Visibility="{Binding LogsDiagnosticsSettingsSectionVisibility}">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                                   Text="{Binding LogsDiagnosticsSettingsTitleText}" />
                                        <Button Grid.Column="1"
                                                Padding="10,5"
                                                AutomationProperties.AutomationId="SettingsCopyLogButton"
                                                Command="{Binding CopyFullLogCommand}"
                                                Content="{Binding CopyFullLogText}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>
                                    <TextBlock Margin="0,0,0,12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding LogsDiagnosticsSettingsIntroText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,0,0,4"
                                               FontWeight="SemiBold"
                                               Text="{Binding LogsDiagnosticsTechnicalDetailsTitleText}" />
                                    <Border Padding="8"
                                            Background="{DynamicResource LogBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <TextBox MinHeight="240"
                                                 AcceptsReturn="True"
                                                 Background="{DynamicResource LogBackgroundBrush}"
                                                 BorderThickness="0"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 IsReadOnly="True"
                                                 Text="{Binding LogsDiagnosticsTechnicalDetailsText, Mode=OneWay}"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto">
                                            <TextBox.Resources>
                                                <Style BasedOn="{StaticResource TechnicalLogScrollBarStyle}"
                                                       TargetType="ScrollBar" />
                                            </TextBox.Resources>
                                            <TextBox.ContextMenu>
                                                <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                                    <MenuItem Header="Copy"
                                                              Command="ApplicationCommands.Copy"
                                                              CommandTarget="{Binding PlacementTarget,
                                                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="Select all"
                                                              Command="ApplicationCommands.SelectAll"
                                                              CommandTarget="{Binding PlacementTarget,
                                                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </TextBox.ContextMenu>
                                        </TextBox>
                                    </Border>
                                </StackPanel>

                                <StackPanel AutomationProperties.AutomationId="AboutLicensesSettingsSection"
                                            Visibility="{Binding AboutLicensesSettingsSectionVisibility}">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="{Binding AboutLicensesSettingsTitleText}" />
                                    <TextBlock Text="{Binding AboutLicensesText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,14,0,4"
                                               FontWeight="SemiBold"
                                               Text="{Binding AboutModelNoticesTitleText}" />
                                    <TextBlock Text="{Binding AboutModelNoticesText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <TextBox Grid.Row="1"
                             MinHeight="220"
                             AcceptsReturn="True"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Text="{Binding TechnicalDetailsBodyText, Mode=OneWay}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding TechnicalDetailsModalContentVisibility}">
                        <TextBox.Resources>
                            <Style BasedOn="{StaticResource TechnicalLogScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </TextBox.Resources>
                        <TextBox.ContextMenu>
                            <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                <MenuItem Header="Copy"
                                          Command="ApplicationCommands.Copy"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Select all"
                                          Command="ApplicationCommands.SelectAll"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>

                    <TextBox Grid.Row="1"
                             MinHeight="220"
                             AcceptsReturn="True"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             Text="{Binding ProfileDetailsBodyText, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding ProfileDetailsModalContentVisibility}">
                        <TextBox.Resources>
                            <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </TextBox.Resources>
                        <TextBox.ContextMenu>
                            <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                <MenuItem Header="Copy"
                                          Command="ApplicationCommands.Copy"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Select all"
                                          Command="ApplicationCommands.SelectAll"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>

                    <TextBox Grid.Row="1"
                             MinHeight="220"
                             AcceptsReturn="True"
                             Background="{DynamicResource LogBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Text="{Binding ActivityLogModalText, Mode=OneWay}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding ActivityLogModalContentVisibility}">
                        <TextBox.Resources>
                            <Style BasedOn="{StaticResource TechnicalLogScrollBarStyle}"
                                   TargetType="ScrollBar" />
                        </TextBox.Resources>
                        <TextBox.ContextMenu>
                            <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                <MenuItem Header="Copy"
                                          Command="ApplicationCommands.Copy"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Select all"
                                          Command="ApplicationCommands.SelectAll"
                                          CommandTarget="{Binding PlacementTarget,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>

                    <Grid Grid.Row="1"
                          Visibility="{Binding PreviewGeneratingModalContentVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding PreviewGeneratingMessageText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding PreviewStageText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                                   Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding PreviewStatusText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding PreviewModalDetailText}"
                                   TextWrapping="Wrap" />
                        <StackPanel Grid.Row="4"
                                    Margin="0,8,0,10"
                                    VerticalAlignment="Top">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ConversionExecutionProgressLabel}" />
                                <TextBlock HorizontalAlignment="Right"
                                           FontWeight="SemiBold"
                                           Text="{Binding PreviewProgressText}" />
                            </Grid>
                            <ProgressBar Maximum="100"
                                         IsIndeterminate="{Binding PreviewProgressIsIndeterminate}"
                                         Value="{Binding PreviewProgressPercent, Mode=OneWay}"
                                         Style="{StaticResource V3dfyProgressBarStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Row="5"
                                    Margin="0,8,0,0">
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding PreviewEngineText}"
                                       ToolTip="{Binding PreviewRunningWithText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding PreviewGpuMetricsNoteText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding PreviewGpuMetricsStatusText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ListBox x:Name="PreviewGenerationLogList"
                                 Grid.Row="7"
                                 MinHeight="240"
                                 Padding="8"
                                 Background="{DynamicResource LogBackgroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 ItemsSource="{Binding PreviewGenerationLogs}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Resources>
                                <Style BasedOn="{StaticResource TechnicalLogScrollBarStyle}"
                                       TargetType="ScrollBar" />
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Background="Transparent"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             HorizontalScrollBarVisibility="Disabled"
                                             IsReadOnly="True"
                                             Padding="0"
                                             Text="{Binding ., Mode=OneWay}"
                                             TextWrapping="NoWrap">
                                        <TextBox.ContextMenu>
                                            <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                                <MenuItem Header="Copy"
                                                          Command="ApplicationCommands.Copy"
                                                          CommandTarget="{Binding PlacementTarget,
                                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="Select all"
                                                          Command="ApplicationCommands.SelectAll"
                                                          CommandTarget="{Binding PlacementTarget,
                                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Grid>

                    <Grid Grid.Row="1"
                          IsVisibleChanged="OnPreviewReadyModalVisibilityChanged"
                          Visibility="{Binding PreviewReadyModalContentVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding PreviewReadyMessageText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding PreviewStatusText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding PreviewOutputPathText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding PreviewOutputPathVisibility}" />
                        <Border Grid.Row="4"
                                MinHeight="280"
                                Background="{DynamicResource LogBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding EmbeddedPreviewVisibility}">
                            <MediaElement x:Name="PreviewMediaElement"
                                          LoadedBehavior="Manual"
                                          MediaEnded="OnPreviewMediaEnded"
                                          MediaFailed="OnPreviewMediaFailed"
                                          MediaOpened="OnPreviewMediaOpened"
                                          ScrubbingEnabled="True"
                                          Source="{Binding PreviewMediaSource}"
                                          Stretch="Uniform"
                                          UnloadedBehavior="Manual"
                                          Volume="0.7" />
                        </Border>
                        <Grid Grid.Row="5"
                              Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PreviewPlayPauseButton"
                                    Margin="0,0,8,0"
                                    AutomationProperties.Name="{Binding PreviewPlayText}"
                                    Click="OnPreviewPlayPauseClicked"
                                    Content="&#xE768;"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{Binding PreviewPlayText}" />
                            <Slider x:Name="PreviewTimelineSlider"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Minimum="0"
                                    PreviewMouseDown="OnPreviewTimelinePreviewMouseDown"
                                    PreviewMouseUp="OnPreviewTimelinePreviewMouseUp"
                                    Style="{StaticResource PreviewSliderStyle}"
                                    ValueChanged="OnPreviewTimelineValueChanged" />
                            <TextBlock x:Name="PreviewTimeText"
                                       Grid.Column="2"
                                       MinWidth="92"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Text="00:00 / 00:00" />
                            <TextBlock x:Name="PreviewVolumeIcon"
                                       Grid.Column="3"
                                       Margin="0,0,8,0"
                                       AutomationProperties.Name="{Binding PreviewVolumeText}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Text="&#xE767;"
                                       ToolTip="{Binding PreviewVolumeText}" />
                            <Slider x:Name="PreviewVolumeSlider"
                                    Grid.Column="4"
                                    Minimum="0"
                                    Maximum="1"
                                    PreviewMouseLeftButtonDown="OnPreviewVolumeSliderPreviewMouseLeftButtonDown"
                                    Style="{StaticResource PreviewSliderStyle}"
                                    Value="0.7"
                                    ValueChanged="OnPreviewVolumeValueChanged" />
                            <ToggleButton x:Name="PreviewMuteToggleButton"
                                          Grid.Column="5"
                                          Margin="8,0,0,0"
                                          AutomationProperties.Name="{Binding PreviewMuteText}"
                                          Checked="OnPreviewMuteChanged"
                                          Content="&#xE74F;"
                                          Style="{StaticResource IconToggleButtonStyle}"
                                          ToolTip="{Binding PreviewMuteText}"
                                          Unchecked="OnPreviewMuteChanged" />
                        </Grid>
                        <TextBlock x:Name="PreviewPlaybackStatusText"
                                   Grid.Row="6"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding PreviewPlaybackFallbackText}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding ModelHelpModalContentVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding ModelHelpIntroText}"
                                   TextWrapping="Wrap" />
                        <Border Grid.Row="2"
                                MinHeight="260"
                                AutomationProperties.AutomationId="ModelHelpContent"
                                Background="{DynamicResource LogBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource TableHeaderBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.35*" />
                                            <ColumnDefinition Width="1.65*" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.1*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpModelHeaderText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpPurposeHeaderText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2"
                                                   Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpUseHeaderText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3"
                                                   Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpSceneHeaderText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="4"
                                                   Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpDepthHeaderText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="5"
                                                   Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ModelHelpSizePerformanceHeaderText}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                               TargetType="ScrollBar" />
                                    </ScrollViewer.Resources>
                                    <ItemsControl AlternationCount="2"
                                                  ItemsSource="{Binding ModelHelpRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource StripedTableRowBorderStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="1.35*" />
                                                            <ColumnDefinition Width="1.65*" />
                                                            <ColumnDefinition Width="0.75*" />
                                                            <ColumnDefinition Width="0.8*" />
                                                            <ColumnDefinition Width="1.1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Model}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding Purpose}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="2"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding Use}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="3"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding Scene}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="4"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding Depth}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Grid.Column="5"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding SizePerformance}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding ModelInventoryModalContentVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar" />
                            </ScrollViewer.Resources>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ModelInventoryIntroText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding ModelInventoryFolderLabelText}" />
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ModelInventoryFolderPathText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,14,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectableModelsSectionTitleText}" />
                                <Border MinHeight="128"
                                        MaxHeight="260"
                                        AutomationProperties.AutomationId="SelectableModelsInventory"
                                        Background="{DynamicResource LogBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Style="{StaticResource TableHeaderBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.3*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                    <ColumnDefinition Width="1.8*" />
                                                    <ColumnDefinition Width="0.75*" />
                                                    <ColumnDefinition Width="0.9*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SelectableModelNameHeaderText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="8,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding SelectableModelIw3HeaderText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding SelectableModelCheckpointHeaderText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="3"
                                                           Margin="8,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding SelectableModelTypeHeaderText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="4"
                                                           Margin="8,0,0,0"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding SelectableModelSourceHeaderText}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                        <ScrollViewer Grid.Row="1"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ScrollViewer.Resources>
                                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                                       TargetType="ScrollBar" />
                                            </ScrollViewer.Resources>
                                            <ItemsControl AlternationCount="2"
                                                          ItemsSource="{Binding SelectableModelInventoryRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource StripedTableRowBorderStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="1.3*" />
                                                                    <ColumnDefinition Width="0.9*" />
                                                                    <ColumnDefinition Width="1.8*" />
                                                                    <ColumnDefinition Width="0.75*" />
                                                                    <ColumnDefinition Width="0.9*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Model}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="1"
                                                                           Margin="8,0,0,0"
                                                                           Text="{Binding Iw3DepthModel}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="2"
                                                                           Margin="8,0,0,0"
                                                                           Text="{Binding Checkpoint}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="3"
                                                                           Margin="8,0,0,0"
                                                                           Text="{Binding Type}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="4"
                                                                           Margin="8,0,0,0"
                                                                           Text="{Binding Source}"
                                                                           TextWrapping="Wrap" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,14,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding DiagnosticModelsSectionTitleText}" />
                                <TextBox MinHeight="96"
                                         AcceptsReturn="True"
                                         AutomationProperties.AutomationId="DiagnosticModelsInventory"
                                         Background="{DynamicResource LogBackgroundBrush}"
                                         BorderBrush="{DynamicResource CardBorderBrush}"
                                         FontFamily="Segoe UI"
                                         FontSize="13"
                                         HorizontalScrollBarVisibility="Disabled"
                                         IsReadOnly="True"
                                         Text="{Binding DiagnosticModelsInventoryText, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto">
                                    <TextBox.Resources>
                                        <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                               TargetType="ScrollBar" />
                                    </TextBox.Resources>
                                    <TextBox.ContextMenu>
                                        <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                            <MenuItem Header="Copy"
                                                      Command="ApplicationCommands.Copy"
                                                      CommandTarget="{Binding PlacementTarget,
                                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Select all"
                                                      Command="ApplicationCommands.SelectAll"
                                                      CommandTarget="{Binding PlacementTarget,
                                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </TextBox.ContextMenu>
                                </TextBox>

                                <TextBlock Margin="0,14,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding RuntimeDependenciesSectionTitleText}" />
                                <TextBox MinHeight="82"
                                         AcceptsReturn="True"
                                         AutomationProperties.AutomationId="RuntimeDependenciesInventory"
                                         Background="{DynamicResource LogBackgroundBrush}"
                                         BorderBrush="{DynamicResource CardBorderBrush}"
                                         FontFamily="Segoe UI"
                                         FontSize="13"
                                         HorizontalScrollBarVisibility="Disabled"
                                         IsReadOnly="True"
                                         Text="{Binding RuntimeDependenciesInventoryText, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto">
                                    <TextBox.Resources>
                                        <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                               TargetType="ScrollBar" />
                                    </TextBox.Resources>
                                    <TextBox.ContextMenu>
                                        <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                            <MenuItem Header="Copy"
                                                      Command="ApplicationCommands.Copy"
                                                      CommandTarget="{Binding PlacementTarget,
                                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Select all"
                                                      Command="ApplicationCommands.SelectAll"
                                                      CommandTarget="{Binding PlacementTarget,
                                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </TextBox.ContextMenu>
                                </TextBox>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer Grid.Column="1"
                                      Margin="18,0,0,0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar" />
                            </ScrollViewer.Resources>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding ModelInventoryActionsTitleText}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding ModelPackImportInstructionText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding ModelPackImportStatusText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding LastModelPackImportSummary}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding LastModelPackImportSummaryVisibility}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Row="1"
                          Visibility="{Binding ModelPackImportConfirmationModalContentVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding ModelPackImportConfirmationIntroText}"
                                   TextWrapping="Wrap" />
                        <TextBox Grid.Row="2"
                                 MinHeight="280"
                                 AcceptsReturn="True"
                                 AutomationProperties.AutomationId="ModelPackImportConfirmationSummary"
                                 Background="{DynamicResource LogBackgroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 HorizontalScrollBarVisibility="Disabled"
                                 IsReadOnly="True"
                                 Text="{Binding ModelPackImportConfirmationMessageText, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto">
                            <TextBox.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar" />
                            </TextBox.Resources>
                            <TextBox.ContextMenu>
                                <ContextMenu Style="{StaticResource V3dfyContextMenuStyle}">
                                    <MenuItem Header="Copy"
                                              Command="ApplicationCommands.Copy"
                                              CommandTarget="{Binding PlacementTarget,
                                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Select all"
                                              Command="ApplicationCommands.SelectAll"
                                              CommandTarget="{Binding PlacementTarget,
                                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding ReplaceSelectedVideoBodyText}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />

                    <TextBlock Grid.Row="1"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding PreviewInvalidationConfirmationBodyText}"
                               TextWrapping="Wrap"
                               Visibility="{Binding PreviewInvalidationConfirmationModalContentVisibility}" />

                    <Grid Grid.Row="1"
                          Visibility="{Binding ConversionCompletedModalContentVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding ConversionCompletedBodyText}"
                                   TextWrapping="Wrap" />
                        <Border Grid.Row="2"
                                Padding="12"
                                Background="{DynamicResource LogBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <TextBlock AutomationProperties.AutomationId="ConversionCompletedOutputPath"
                                       Text="{Binding ConversionCompletedOutputPathText}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button AutomationProperties.AutomationId="CancelModelPackImportButton"
                                Command="{Binding CancelModelPackImportCommand}"
                                Content="{Binding CancelDialogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ModelPackImportConfirmationModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="ConfirmModelPackImportButton"
                                Command="{Binding ConfirmModelPackImportCommand}"
                                Content="{Binding ModelPackImportConfirmationContinueText}"
                                Visibility="{Binding ModelPackImportConfirmationModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="ImportModelPackButton"
                                Command="{Binding ImportModelPackCommand}"
                                Content="{Binding ImportModelPackText}"
                                IsEnabled="{Binding CanImportModelPack}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ModelInventoryModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="OpenModelsFolderButton"
                                Command="{Binding OpenModelsFolderCommand}"
                                Content="{Binding OpenModelsFolderText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ModelInventoryModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="CloseModelHelpButton"
                                Command="{Binding CloseModelHelpCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding ModelHelpModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="CloseModelInventoryButton"
                                Command="{Binding CloseModelInventoryCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding ModelInventoryModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CancelReplaceVideoButton"
                                Command="{Binding CancelReplaceVideoCommand}"
                                Content="{Binding CancelDialogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="ConfirmReplaceVideoButton"
                                Command="{Binding ConfirmReplaceVideoCommand}"
                                Content="{Binding ReplaceVideoConfirmText}"
                                Visibility="{Binding ReplaceVideoConfirmationModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CancelPreviewInvalidationButton"
                                Command="{Binding CancelPreviewInvalidationCommand}"
                                Content="{Binding CancelDialogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding PreviewInvalidationConfirmationModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="ConfirmPreviewInvalidationButton"
                                Command="{Binding ConfirmPreviewInvalidationCommand}"
                                Content="{Binding PreviewInvalidationConfirmText}"
                                Visibility="{Binding PreviewInvalidationConfirmationModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="AcceptConversionCompletedButton"
                                Command="{Binding AcceptConversionCompletedCommand}"
                                Content="{Binding AcceptConversionCompletedText}"
                                Visibility="{Binding ConversionCompletedModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CopyFullLogButton"
                                Command="{Binding CopyFullLogCommand}"
                                Content="{Binding CopyFullLogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding ActivityLogModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="CloseActivityLogButton"
                                Command="{Binding CloseActivityLogCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding ActivityLogModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CopyPreviewLogButton"
                                Margin="8,0,0,0"
                                Command="{Binding CopyPreviewLogCommand}"
                                Content="{Binding CopyPreviewLogText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding PreviewGeneratingModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CancelPreviewButton"
                                Margin="8,0,0,0"
                                MinHeight="44"
                                Padding="16,11"
                                Command="{Binding CancelPreviewCommand}"
                                Content="{Binding CancelPreviewText}"
                                Style="{StaticResource DestructiveButtonStyle}"
                                Visibility="{Binding PreviewGeneratingModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="OpenPreviewExternallyButton"
                                Command="{Binding OpenPreviewCommand}"
                                Content="{Binding OpenPreviewExternallyText}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding PreviewReadyModalContentVisibility}" />
                        <Button Margin="8,0,0,0"
                                AutomationProperties.AutomationId="ContinuePreviewButton"
                                Command="{Binding ContinuePreviewCommand}"
                                Content="{Binding ContinuePreviewText}"
                                Visibility="{Binding PreviewReadyModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CloseTechnicalDetailsButton"
                                Command="{Binding CloseTechnicalDetailsCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding TechnicalDetailsModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CloseProfileDetailsButton"
                                Command="{Binding CloseProfileDetailsCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding ProfileDetailsModalContentVisibility}" />
                        <Button AutomationProperties.AutomationId="CloseSettingsButton"
                                Command="{Binding CloseSettingsCommand}"
                                Content="{Binding CloseDialogText}"
                                Visibility="{Binding SettingsModalContentVisibility}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="30"
              AutomationProperties.AutomationId="GlobalBusyOverlay"
              Background="#80000000"
              Visibility="{Binding GlobalBusyOverlayVisibility}">
            <Border Width="320"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource V3dfyModalCardStyle}">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding GlobalBusyText}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <ProgressBar Height="6"
                                 Margin="0,16,0,0"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
