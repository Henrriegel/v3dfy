<Window x:Class="V3dfy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Width="1120"
        Height="800"
        MinWidth="920"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        Drop="OnDrop">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        </Style>
        <Style x:Key="WorkflowTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel Background="Transparent"
                                      IsItemsHost="True" />
                            <Border Grid.Row="1"
                                    Padding="14"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WorkflowTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TabUnselectedForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource TabUnselectedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0">
                            <Grid>
                                <Border x:Name="AccentLine"
                                        Height="3"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource TabAccentBrush}"
                                        CornerRadius="3,3,0,0"
                                        Opacity="0" />
                                <ContentPresenter Margin="0,2,0,0"
                                                  ContentSource="Header"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource ComboBoxHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TabSelectedForegroundBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource TabSelectedBackgroundBrush}" />
                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource TabSelectedBorderBrush}" />
                                <Setter TargetName="AccentLine"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24"
          Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding AppTitle}" />
                <TextBlock Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SubtitleText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding LanguageLabel}" />
                <ComboBox Margin="0,0,16,0"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedItem="{Binding SelectedLanguage}" />
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding ThemeLabel}" />
                <ComboBox ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding SelectedTheme}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Margin="0,0,4,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                           TargetType="ScrollBar" />
                </ScrollViewer.Resources>
                <Grid Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding SelectSourceTitle}" />
                        <Border Padding="20"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DropVideoText}" />
                                <TextBlock Margin="0,6,0,14"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text=".mp4, .mkv, .avi, .mov, .m4v, .webm" />
                                <TextBlock Margin="0,0,0,14"
                                           Text="{Binding SelectedVideoDisplayPath}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding SelectVideoCommand}"
                                            Content="{Binding SelectVideoText}" />
                                    <Button Margin="10,0,0,0"
                                            Command="{Binding AnalyzeCommand}"
                                            Content="{Binding AnalyzeText}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <TabControl SelectedIndex="{Binding SelectedWorkflowTabIndex,
                                                        Mode=TwoWay}"
                                Style="{StaticResource WorkflowTabControlStyle}">
                        <TabItem Header="{Binding VideoAnalysisTitle}"
                                 Style="{StaticResource WorkflowTabItemStyle}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding AnalysisStatusText}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AnalysisDurationText}" />
                                        <TextBlock Text="{Binding AnalysisResolutionText}" />
                                        <TextBlock Text="{Binding AnalysisFpsText}" />
                                        <TextBlock Text="{Binding AnalysisCodecText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding AnalysisContainerText}" />
                                        <TextBlock Text="{Binding AnalysisAudioStreamsText}" />
                                        <TextBlock Text="{Binding AnalysisSubtitleStreamsText}" />
                                        <TextBlock Text="{Binding AnalysisHdrText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding AnalysisCompatibilityText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{Binding RecommendedSetupTitle}"
                                 Style="{StaticResource WorkflowTabItemStyle}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding RecommendedSetupStatusText}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding RecommendedOutputContainerText}" />
                                        <TextBlock Text="{Binding RecommendedVideoCodecText}" />
                                        <TextBlock Text="{Binding RecommendedAudioCodecText}" />
                                        <TextBlock Text="{Binding RecommendedResolutionText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding RecommendedThreeDLayoutText}" />
                                        <TextBlock Text="{Binding RecommendedQualityText}" />
                                        <TextBlock Text="{Binding RecommendedIntensityText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Margin="0,10,0,4"
                                           FontWeight="SemiBold"
                                           Text="{Binding RecommendedNotesTitle}" />
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding RecommendedNotesText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding RecommendedPresetTitle}" />
                        <TextBlock FontWeight="SemiBold" Text="{Binding PresetName}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding PresetContainerText}" />
                        <TextBlock Text="{Binding PresetVideoCodecText}" />
                        <TextBlock Text="{Binding PresetAudioCodecText}" />
                        <TextBlock Text="{Binding PresetResolutionText}" />
                        <TextBlock Text="{Binding PresetThreeDLayoutText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding PresetAdvancedOutputText}" />
                        <Border Margin="0,10,0,0"
                                Padding="8"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding TvPlaybackTitle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="{Binding TvPlaybackInstructions}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                </Grid>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding ToolStatusTitle}" />
                            <Button Grid.Column="1"
                                    Margin="0,0,0,8"
                                    Padding="10,5"
                                    Command="{Binding RefreshEngineStatusCommand}"
                                    Content="{Binding RefreshText}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ToolStatuses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        MinHeight="160"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="{Binding ActivityLogTitle}" />
                            <Button Grid.Column="1"
                                    Margin="0,0,0,8"
                                    Padding="10,5"
                                    Command="{Binding ClearLogsCommand}"
                                    Content="{Binding ClearText}" />
                        </Grid>
                        <ListBox Grid.Row="1"
                                 MinHeight="90"
                                 Padding="8"
                                 Background="{DynamicResource LogBackgroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 ItemsSource="{Binding Logs}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Resources>
                                <Style BasedOn="{StaticResource ModernVerticalScrollBarStyle}"
                                       TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Width" Value="Auto" />
                                            <Setter Property="MinWidth" Value="0" />
                                            <Setter Property="Height" Value="10" />
                                            <Setter Property="MinHeight" Value="10" />
                                            <Setter Property="Template"
                                                    Value="{StaticResource ModernHorizontalScrollBarTemplate}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource PrimaryTextBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="2" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding DisplayText}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
