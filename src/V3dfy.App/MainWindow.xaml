                        <TextBox Grid.Row="1"
                                 MinHeight="160"
                                 AcceptsReturn="True"
                                 Background="{DynamicResource LogBackgroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 Text="{Binding ActivityLogPanelText, Mode=OneWay}"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto">
